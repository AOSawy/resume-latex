% =============================================================
%  preamble.sty — Resume style for Abdelrahman O. Sawy
%  Overleaf-compatible; all packages are on TeX Live / Overleaf
% =============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{preamble}[2026/03/27 Resume preamble v1.0]

% ---------------------------
%  Page layout
% ---------------------------
\usepackage[
  top    = 0.55in,
  bottom = 0.50in,
  left   = 0.65in,
  right  = 0.65in,
  nohead,
  nofoot
]{geometry}

% ---------------------------
%  Encoding & typography
% ---------------------------
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{charter}          % Elegant serif — renders cleanly on screen & in print
\usepackage{microtype}        % Improved kerning, reduces overfull hboxes

% ---------------------------
%  Colour palette  (one accent colour only — ATS-safe)
% ---------------------------
\usepackage{xcolor}
\definecolor{navyblue}{HTML}{1F3A5F}   % deep navy — professional, not garish
\definecolor{subtlegray}{HTML}{666666}

% ---------------------------
%  Section heading format
%  ATS-safe: section titles are plain text; colour is cosmetic only
% ---------------------------
\usepackage{titlesec}
\titleformat{\section}
  {\color{navyblue}\normalfont\large\bfseries\uppercase}
  {}
  {0em}
  {}
  [\vspace{-4pt}\color{navyblue}\rule{\linewidth}{0.6pt}]

\titlespacing*{\section}
  {0pt}       % left indent
  {7pt}       % space before
  {3pt}       % space after

% ---------------------------
%  List formatting
% ---------------------------
\usepackage{enumitem}
\setlist[itemize]{
  leftmargin = 1.4em,
  topsep     = 1.5pt,
  itemsep    = 1.5pt,
  parsep     = 0pt,
  label      = \textbullet
}

% ---------------------------
%  Hyperlinks  (ATS reads underlying text; colour does not affect parsing)
% ---------------------------
\usepackage[
  colorlinks = true,
  urlcolor   = navyblue,
  linkcolor  = navyblue,
  pdftitle   = {Abdelrahman O. Sawy --- Resume},
  pdfauthor  = {Abdelrahman O. Sawy}
]{hyperref}

% ---------------------------
%  Paragraph & spacing helpers
% ---------------------------
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\pagestyle{empty}             % no page numbers on resume

% ---------------------------
%  Convenience commands
% ---------------------------

% \entry{Title}{Date}  — bold title left, italic date right
\newcommand{\entry}[2]{%
  \noindent\textbf{#1}\hfill\textit{#2}%
}

% \subentry{Subtitle}  — italic subtitle, no date
\newcommand{\subentry}[1]{%
  \noindent\textit{#1}%
}

% Vertical gap between experience blocks
\newcommand{\entrysep}{\vspace{5pt}}

% Thin separator between subsections (not needed every time)
\newcommand{\thinsep}{\vspace{3pt}}
